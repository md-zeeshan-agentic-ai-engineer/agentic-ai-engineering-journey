    "import numpy as np\n",
    "\n",
    "def sigmoid(x):\n",
    "    return 1/(1+np.exp(-x))\n",
    "\n",
    "values = [-5, -2, 0, 2, 5]\n",
    "\n",
    "for v in values:\n",
    "    print(v, \"->\", sigmoid(v))"
   ]
